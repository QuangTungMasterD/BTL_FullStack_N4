{
  "Jwt": {
    "Key": "VerySecretSharedJwtKey123!VerySecretKey4567",
    "Issuer": "AttendanceAuth"
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "studentAttendance": {
        "ClusterId": "studentAttendanceCluster",
        "Match": {
          "Path": "/studentattendance/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/studentattendance" }
        ]
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "studentAttendanceCluster": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5216/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*"
}