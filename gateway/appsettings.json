{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "Jwt": {
    "Key": "VerySecretSharedJwtKey123!VerySecretKey4567",
    "Issuer": "AttendanceAuth",
    "ExpirationMinutes": 480
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "attendance-route": {
        "ClusterId": "attendance-cluster",
        "Match": {
          "Path": "/studentattendance/api/{**catch-all}"
        },
        "AuthorizationPolicy": "Bearer"
      },
      "api-route": {
        "ClusterId": "attendance-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "AuthorizationPolicy": "Bearer"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "attendance-cluster": {
        "Destinations": {
          "attendance-destination": {
            "Address": "http://localhost:5216/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}